{
  "name": "mrp-5g-session-processor",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:backend": "pnpm --filter backend run dev",
    "dev:frontend": "pnpm --filter frontend run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "docker:up": "docker compose -f docker/docker-compose.yml up",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:init": "bash docker/init-garage.sh",
    "db:seed": "pnpm --filter backend run seed:users"
  },
  "devDependencies": {
    "eslint": "9.39.2",
    "prettier": "3.7.4",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.58.1"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.14.2"
}
