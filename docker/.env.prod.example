# Application
BASE_PATH=/mrp-5g-session-processor
PORT=3001
CORS_ORIGIN=https://app.example.com
# Cookie secure flag: auto (default, true in production), true, or false
# Set to false for testing on localhost without HTTPS
COOKIE_SECURE=auto

# Session secret (at least 32 characters)
SESSION_SECRET=your-super-secret-session-key-here-min-32-chars

# S3 Storage configuration (Garage is included in docker-compose)
S3_ENDPOINT=http://garage:3900
S3_BUCKET=mrp-videos
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_REGION=garage

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL_TRANSCRIPTION=gpt-4o-transcribe-diarize
OPENAI_MODEL_SEGMENTATION=gpt-5.1
OPENAI_MODEL_METADATA=gpt-5.1

# ElevenLabs API (for simulator)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Simulator configuration
# Format: ID:Name;ID:Name;... (e.g., "abc123:Dr. Smith;def456:Patient Voice;ghi789:Specialist")
SIMULATOR_VOICES=voice-id-1:Dr. Rodriguez;voice-id-2:Patient Voice;voice-id-3:Specialist
SIMULATOR_PAUSE_BETWEEN_SEGMENTS_MS=1000
SIMULATOR_AUDIO_CONCURRENCY=3
