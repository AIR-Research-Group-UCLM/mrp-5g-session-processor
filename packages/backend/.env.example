# Server
NODE_ENV=development
PORT=3001

# Session
SESSION_SECRET=your-super-secret-session-key-at-least-32-chars

# Database
DATABASE_PATH=./data/mrp.db

# CORS
CORS_ORIGIN=http://localhost:5173

# S3 (Garage)
S3_ENDPOINT=http://localhost:3900
S3_BUCKET=mrp-videos
S3_ACCESS_KEY=your-garage-access-key
S3_SECRET_KEY=your-garage-secret-key
S3_REGION=garage

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# OpenAI Models (optional - defaults shown)
OPENAI_MODEL_TRANSCRIPTION=gpt-4o-transcribe-diarize  # Transcripción con identificación de hablantes
OPENAI_MODEL_SEGMENTATION=gpt-5.1                     # Segmentación en secciones médicas y resúmenes por sección
OPENAI_MODEL_METADATA=gpt-5.1                         # Generación de metadatos (resumen, keywords, título, tags)
OPENAI_PRICE_TRANSCRIPTION_PER_MINUTE=0.006           # Precio por minuto de transcripción para gpt-4o-transcribe-diarize (USD)
OPENAI_PRICE_INPUT_PER_1M=1.25                        # Precio por 1M tokens de entrada para gpt-5.1 (USD)
OPENAI_PRICE_OUTPUT_PER_1M=10.0                       # Precio por 1M tokens de salida para gpt-5.1 (USD)

# Open WebUI (optional - for patient inquiry feature)
OPEN_WEBUI_BASE_URL=http://localhost:3000
OPEN_WEBUI_API_KEY=your-open-webui-api-key
OPEN_WEBUI_MODEL=gpt-oss:20b

# ElevenLabs (for session simulator)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_PRICE_PER_1K_CHARS=0.3  # Price per 1000 characters for ElevenLabs TTS (USD)

# Simulator Voices (format: ID:Name;ID:Name;...)
# List available voices from your ElevenLabs account
SIMULATOR_VOICES=voice-id-1:Dr. Rodriguez;voice-id-2:Patient Voice;voice-id-3:Dr. Smith (Specialist)

# Simulator Settings (optional - defaults shown)
SIMULATOR_PAUSE_BETWEEN_SEGMENTS_MS=1000  # Milliseconds of silence between speech segments
SIMULATOR_AUDIO_CONCURRENCY=3              # Number of concurrent audio generation jobs